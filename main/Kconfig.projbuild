menu "Featured FreeRTOS IoT Integration"

    menu "LOGI"

        config LOGI_PROVISION_ENABLED
            bool "Enable provisioning mode"
            default n


        menu "Settings Options"

            config LOGI_DEFAULT_IS_SET_FLAG_VALUE
                hex "Value stored alongside defaults to indicate that the defaults have been set. Is never cleared. Altering this will cause devices using the previous valuye to reset to default values."
                default 0x0001

            config LOGI_DEFAULT_LTE_TIMEOUT_S
                int "Wake mode timeout before returning to sleep when prompted to send data in seconds."
                default 300

            config LOGI_MIN_LTE_TIMEOUT_S
                int "Wake mode timeout before returning to sleep when prompted to send data in seconds."
                default 300

            config LOGI_DEFAULT_FILL_PERCENT_DELTA
                int "The fuel level increase, in percent, that must occur to trigger a 'fill' event."
                default 10

            config LOGI_MIN_FILL_PERCENT_DELTA
                int "The fuel level increase, in percent, that must occur to trigger a 'fill' event."
                default 10

            config LOGI_DEFAULT_FILL_DWELL_TIME_S
                int "The minimum time, in seconds, that the fuel level must remain stable after increase to confirm a fill event."
                default 300

            config LOGI_MIN_FILL_DWELL_TIME_S
                int "The minimum time, in seconds, that the fuel level must remain above the fill threshold to trigger a 'fill' event."
                default 300

            config LOGI_DEFAULT_BLE_ADV_TIME_MS
                int "Default BLE ADV interval during prov mode (ms)"
                default 8000
                help
                    REQ-SHADOW: BLE advertising interval (ms) used during the 48h
                    provisioning window. Shadow-controllable via 'ble_adv_time'.
                    LOGI4W cloud payloads commonly use values such as 120.

            config LOGI_MIN_BLE_ADV_TIME_MS
                int "Minimum BLE ADV interval (ms) — shadow values below this are rejected"
                default 1

            config LOGI_DEFAULT_POST_DWELL_TIME_S
                int "The minimum time, in seconds, that the fuel level must remain above the fill threshold to trigger a 'fill' event."
                default 60

            config LOGI_MIN_POST_DWELL_TIME_S
                int "The minimum time, in seconds, that the fuel level must remain above the fill threshold to trigger a 'fill' event."
                default 30

        endmenu

        menu "Firmware Configuration"

            config LOGI_INITIAL_WAKE_TIME_M
                int "Amount of time to run initialization before returning to sleep."
                default 31

            config SCHEDULE_LOCKOUT_TIME_S
                int "The window of time, in seconds that the scheduled post may occur (and may not re-occur)."
                default 300

            config LOGI_SCHEDULE_HOUR_TIMEZONE_OFFSET
                int "Hour offset from UTC for the scheduled wakeup. (0 = UTC) (-5 = EST)"
                default -5

            config LOGI_FIRMWARE_UPDATE_TIMEOUT_S
                int "Wake mode timeout before returning to sleep in seconds if a firmware update is in progress. (3000 = 50 min.)"
                default 3000

            config LOGI_NO_POST_RESET_TIMEOUT_MS
                int "Timeout for resetting if no posts are succesfully making it out from the AWS module. (43200000 = 12 hours) (4504682496 = 48 hours)"
                default 4504682496

            config LOGI_SLEEP_GRACE_PERIOD_S
                int "Once all transmissions are complete, how long to wait before returning to sleep, Higher values give more time for things like GPS"
                default 10

            config LOGI_BATTERY_VOLTAGE_POST_THRESHOLD_10X
                int "The battery voltage threshold under which the device will not attempt to post. Value is divided by 10 for comparison so 35 == 3.5V."
                default 35

            config LOGI_RGB_INITIAL_WAKE_TIME_M 
                int "Amount of time to display yellow instead of red if no post has occured yet."
                default 10

            config LOGI_RGB_BLINK_INTERVAL_MS
                int "The interval at which the RGB LED will blink in milliseconds."
                default 50

            config LOGI_RGB_OFF_INTERVAL_MS
                int "The interval at which the RGB LED will blink in milliseconds."
                default 950

            config LOGI_RGB_BRIGHTNESS_LEVEL_RED
                int "The brightness level of the RGB LED. (0-255)"
                default 255

            config LOGI_RGB_BRIGHTNESS_LEVEL_GREEN
                int "The brightness level of the RGB LED. (0-255)"
                default 255

            config LOGI_RGB_BRIGHTNESS_LEVEL_YELLOW_RED
                int "The brightness level of the RGB LED. (0-255)"
                default 255

            config LOGI_RGB_BRIGHTNESS_LEVEL_YELLOW_GREEN
                int "The brightness level of the RGB LED. (0-255)"
                default 255

            config LOGI_RGB_BRIGHTNESS_LEVEL_BLUE
                int "The brightness level of the blue LED. (0-255)"
                default 255

            config LOGI_PROVISIONING_TIMEOUT_HOURS
                int "Total time in hours to remain in provisioning mode before deep sleep."
                default 48

            config LOGI_USB_ALLOWS_CHIP_RESET
                bool "USB host attached: keep USB-Serial-JTAG chip-reset path enabled (remote reflash)"
                default y
                help
                    The C6 spurious-self-reset workaround (usb_uart_chip_rst_dis)
                    also blocks esptool's host-initiated reset into the ROM
                    bootloader, making a running unit un-reflashable. With this
                    option, a unit that detects an enumerated USB host at boot
                    keeps the reset path enabled so esptool can reflash it at
                    any time. A spurious 0x15 reset on a bench unit is harmless
                    (it lands in the boot flash window). Field units (no USB
                    host) keep the quirk suppression unchanged.

            config LOGI_USB_BLOCKS_DEEP_SLEEP
                bool "USB host attached: replace deep sleep with awake wait + restart"
                default n
                help
                    When a USB-Serial-JTAG host is enumerated (an actual PC, not
                    just 5V power), Sleep() waits out the duration awake and then
                    restarts instead of entering deep sleep. Keeps bench/test
                    units flashable and serial-monitorable at all times - deep
                    sleep powers down the USB controller and the only access
                    window would be the ~20 s boot countdown after each wake.
                    Field units never enumerate a USB host, so deep-sleep
                    behavior and power draw in the field are unchanged. Disable
                    to measure true deep-sleep current while connected to
                    instrumentation that enumerates as a host.

            config LOGI_BLE_INACTIVITY_TIMEOUT_MIN
                int "Minutes of BLE connection inactivity before dropping the connection."
                default 5

            config LOGI_PROVISIONING_SUCCESS_DISPLAY_MIN
                int "Minutes to blink green LED after successful provisioning before rebooting."
                default 30

            config AWS_IOT_POLL_THREAD_STACK_SIZE
                int "Configures the size of the AWS_IOT Polling thread, which needs to accomodate firmware updates."
                default 4096

            config AWS_IOT_BROKER_HOST_NAME_MAX_LEN
                int "Configures the max length of the broker host name."
                default 100

            config LOGI_UDP_POST_ENABLED
                bool "Enable compact UDP telemetry posts"
                default y
                help
                    Sends each LOGI telemetry snapshot as one compact JSON UDP
                    datagram with an HMAC-SHA256 sig field.

            config LOGI_UDP_POST_HOST
                string "Compact UDP telemetry host"
                depends on LOGI_UDP_POST_ENABLED
                default "udp.centriconnect.com"

            config LOGI_UDP_POST_PORT
                int "Compact UDP telemetry port"
                depends on LOGI_UDP_POST_ENABLED
                default 443

            config LOGI_UDP_POST_HMAC_SECRET
                string "Compact UDP telemetry HMAC shared secret"
                depends on LOGI_UDP_POST_ENABLED
                default ""
                help
                    The exact shared-secret string bytes used as the HMAC key.
                    Hex-looking values are treated as ASCII/UTF-8 text, not
                    decoded binary hex.

        endmenu

        menu "Debug Options"

            config LOGI_UART_DATETIME_TEST
                bool "When enabled, the uart will provide a false datetime if no other is available"
                default n

            config LOGI_DEBUG_USE_HARDCODED_WIFI
                bool "Use hardcoded WiFi credentials (skip provisioning)"
                default n
                help
                    When enabled and no WiFi credentials are stored, automatically
                    use the hardcoded credentials from wifiCredentials.h.
                    For debugging/testing only.

        endmenu  #Debug Options

        menu "Version Info"

            config LOGI_SOFTWARE_VERSION_MAJOR
                int "LOGI CELL firmware major version"
                default 0

            config LOGI_SOFTWARE_VERSION_MINOR
                int "LOGI CELL firmware minor version"
                default 0

            config LOGI_SOFTWARE_VERSION_REVISION
                int "LOGI CELL firmware revision"
                default 0

            config LOGI_HARDWARE_VERSION_MAJOR
                int "LOGI CELL hardware major version"
                default 4

            config LOGI_HARDWARE_VERSION_MINOR
                int "LOGI CELL hardware minor version"
                default 1

            config LOGI_HARDWARE_VERSION_REVISION
                int "LOGI CELL hardware revision"
                default 0

            config LOGI_MQTT_VERSION_MAJOR
                int "LOGI CELL MQTT major version"
                default 4

            config LOGI_MQTT_VERSION_MINOR
                int "LOGI CELL MQTT minor version"
                default 1

            config LOGI_MQTT_VERSION_REVISION
                int "LOGI CELL MQTT revision"
                default 1

        endmenu # Version Info
    endmenu # LOGI

    config APP_WIFI_PROV_SHOW_QR
        bool "Show provisioning QR code"
        default y
        help
            Show the QR code for provisioning.

    choice APP_WIFI_PROV_TRANSPORT
        bool "Provisioning Transport method"
        default APP_WIFI_PROV_TRANSPORT_BLE
        help
            Wi-Fi provisioning component offers both, SoftAP and BLE transports. Choose any one.
    config APP_WIFI_PROV_TRANSPORT_SOFTAP
        bool "Soft AP"
    config APP_WIFI_PROV_TRANSPORT_BLE
        bool "BLE"
        select BT_ENABLED
    endchoice

    config APP_WIFI_PROV_TRANSPORT
        int
        default 1 if APP_WIFI_PROV_TRANSPORT_SOFTAP
        default 2 if APP_WIFI_PROV_TRANSPORT_BLE

    config GRI_RUN_QUALIFICATION_TEST
        bool "Run qualification test."
        default n
        help
            Enable to run qualification test. Use configurations in test_execution_config.h and test_param_config.h.
            Disable to demo. Use configurations below (in sdkconfig).

    menu "Qualification Test Configurations"

        menu "Qualification Execution Test Configurations"
            config GRI_DEVICE_ADVISOR_TEST_ENABLED
                bool "Device Advisor Test."
                default n

            config GRI_MQTT_TEST_ENABLED
                bool "MQTT Test."
                default n

            config GRI_TRANSPORT_INTERFACE_TEST_ENABLED
                bool "Transport Interface Test."
                default n

            config GRI_CORE_PKCS11_TEST_ENABLED
                bool "CorePKCS#11 Test."
                default n

        endmenu # "Qualification Execution Test Configurations"

        menu "Qualification Parameter Configurations"
            config GRI_QUALIFICATION_FORCE_GENERATE_NEW_KEY_PAIR
                bool "Generate a key pair."
                default n

            config GRI_QUALIFICATION_MQTT_ENDPOINT
                string "Endpoint for MQTT Broker to use"
                default "PLACE_HOLDER"
                help
                    MQTT Broker for Device Advisor Test/MQTT Test/OTA end-to-end Test.

            config GRI_QUALIFICATION_MQTT_PORT
                int "Port for MQTT Broker to use"
                default 8883

            config GRI_QUALIFICATION_CLIENT_IDENTIFIER
                string "Client Identifier for MQTT Test"
                default "PLACE_HOLDER"

            config GRI_QUALIFICATION_NETWORK_BUFFER_SIZE
                int "Network Buffer Size for MQTT Test"
                default 5000

            config GRI_QUALIFICATION_PROCESS_LOOP_TIMEOUT_MS
                int "Timeout to run MQTT process loop for MQTT Test"
                default 700

            config GRI_QUALIFICATION_ECHO_SERVER
                string "Echo Server Domain Name/IP for Transport Interface Test"
                default "PLACE_HOLDER"
                help
                    Domain Name or IP address for Transport Interface Test.

            config GRI_QUALIFICATION_ECHO_SERVER_PORT
                int "Port for Echo Server to use"
                default 9000

            config GRI_QUALIFICATION_THING_NAME
                string "Thing Name for Device Advisor Test/OTA end-to-end Test"
                default "PLACE_HOLDER"

        endmenu # "Qualification Parameter Configurations"

        menu "Sub pub unsub demo configurations"
            config GRI_SUB_PUB_UNSUB_DEMO_STRING_BUFFER_LENGTH
                int "Topic name and payload buffer length"
                default 100
                help
                    Size of statically allocated buffers for holding topic names and payloads.

            config GRI_SUB_PUB_UNSUB_DEMO_DELAY_BETWEEN_SUB_PUB_UNSUB_LOOPS_MS
                int "Delay between sub pub unsub loops in milliseconds"
                default 5000
                help
                    Delay for each task between subscription, publish, unsubscription loops.

            config GRI_SUB_PUB_UNSUB_DEMO_MAX_COMMAND_SEND_BLOCK_TIME_MS
                int "coreMQTT-Agent command post block time in milliseconds."
                default 500
                help
                    The maximum amount of time in milliseconds to wait for the commands to be posted to the MQTT agent should the MQTT agent's command queue be full. Tasks wait in the Blocked state, so don't use any CPU time.

            config GRI_SUB_PUB_UNSUB_DEMO_QOS_LEVEL
                int "QoS level of MQTT operations"
                default 1
                range 0 2
                help
                    The QoS level of MQTT messages sent by this demo. This must be 0 or 1 if using AWS as AWS only supports levels 0 or 1. If using another MQTT broker, that supports QoS level 2, this can be set to 2.

            config GRI_SUB_PUB_UNSUB_DEMO_NUM_TASKS_TO_CREATE
                int "Number of SubPubUnsub tasks to create"
                default 1
                help
                    The number of SubPubUnsub tasks to create for this demo.

            config GRI_SUB_PUB_UNSUB_DEMO_TASK_PRIORITY
                int "SubPubUnsub task priority."
                default 1
                help
                    The task priority of each of the SubPubUnsub tasks.

            config GRI_SUB_PUB_UNSUB_DEMO_TASK_STACK_SIZE
                int "SubPubUnsub task stack size."
                default 3072
                help
                    The task stack size for each of the SubPubUnsub tasks.

        endmenu # Sub pub unsub demo configurations

        menu "OTA demo configurations"
            config GRI_OTA_DEMO_MAX_FILE_PATH_SIZE
                int "Max file path size."
                default 260
                help
                    The maximum size of the file paths used in the demo.

            config GRI_OTA_DEMO_MAX_STREAM_NAME_SIZE
                int "Max stream name size."
                default 128
                help
                    The maximum size of the stream name required for downloading update file from streaming service.

            config GRI_OTA_DEMO_TASK_DELAY_MS
                int "OTA statistic output delay milliseconds."
                default 1000
                help
                    The delay used in the OTA demo task to periodically output the OTA statistics like number of packets received, dropped, processed and queued per connection.

            config GRI_OTA_DEMO_MQTT_TIMEOUT_MS
                int "MQTT operation timeout milliseconds."
                default 5000
                help
                    The maximum time for which OTA demo waits for an MQTT operation to be complete. This involves receiving an acknowledgment for broker for SUBSCRIBE, UNSUBSCRIBE and non QOS0 publishes.

            config GRI_OTA_DEMO_AGENT_TASK_PRIORITY
                int "OTA agent task priority."
                default 4

            config GRI_OTA_DEMO_AGENT_TASK_STACK_SIZE
                int "OTA agent task stack size."
                default 4096

            config GRI_OTA_DEMO_DEMO_TASK_PRIORITY
                int "OTA demo task priority."
                default 1

            config GRI_OTA_DEMO_DEMO_TASK_STACK_SIZE
                int "OTA demo task stack size."
                default 3072

            config GRI_OTA_MAX_NUM_DATA_BUFFERS
                int "OTA buffer number."
                default 2

        endmenu # OTA demo configurations
    endmenu # Qualification Test Configurations

    config GRI_MQTT_ENDPOINT
        string "Endpoint for MQTT Broker to use"
        depends on !GRI_RUN_QUALIFICATION_TEST
        default ""

    config GRI_MQTT_PORT
        int "Port for MQTT Broker to use"
        depends on !GRI_RUN_QUALIFICATION_TEST
        default 8883

    config GRI_THING_NAME
        string "Thing name"
        depends on !GRI_RUN_QUALIFICATION_TEST
        default ""

    config GRI_OUTPUT_CERTS_KEYS
        bool "Output provisioned certificates and keys."
        default y

    menu "coreMQTT-Agent Manager Configurations"

        config GRI_MQTT_AGENT_TASK_STACK_SIZE
            int "coreMQTT-Agent task stack size"
            default 4096

        config GRI_MQTT_AGENT_TASK_PRIORITY
            int "coreMQTT-Agent task priority"
            default 4

        config GRI_CONNECTION_TASK_STACK_SIZE
            int "Connection handling task stack size"
            default 3072

        config GRI_CONNECTION_TASK_PRIORITY
            int "Connection handling task priority"
            default 4

        config GRI_RETRY_MAX_BACKOFF_DELAY_MS
            int "Maximum backoff delay on connection retry in milliseconds"
            default 5000

        config GRI_RETRY_BACKOFF_BASE_MS
            int "Base back-off delay on connection retry in milliseconds"
            default 500

        config GRI_MQTT_AGENT_NETWORK_BUFFER_SIZE
            int "coreMQTT-Agent network buffer size"
            default 10000

        config GRI_MQTT_AGENT_COMMAND_QUEUE_LENGTH
            int "coreMQTT-Agent command queue length"
            default 10

        config GRI_MQTT_AGENT_KEEP_ALIVE_INTERVAL_SECONDS
            int "coreMQTT-Agent keep alive interval in seconds"
            default 60
            help
                The maximum time interval in seconds which is allowed to elapsed between two Control Packets.

        config GRI_MQTT_AGENT_CONNACK_RECV_TIMEOUT_MS
            int "Timeout for receiving CONNACK in milliseconds"
            default 1000


    endmenu # coreMQTT-Agent Manager Configurations

    config GRI_ENABLE_SUB_PUB_UNSUB_DEMO
